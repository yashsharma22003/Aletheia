# =============================================================================
#  Aletheia Protocol — Environment Variables Reference
#  Copy this file to .env and fill in your values.
#  Never commit your .env file to version control.
# =============================================================================

# ── Deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x

# ── Testnet RPC URLs ───────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<YOUR_INFURA_KEY>
OP_SEPOLIA_RPC_URL=https://optimism-sepolia.infura.io/v3/<YOUR_INFURA_KEY>
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/<YOUR_INFURA_KEY>
ARB_SEPOLIA_RPC_URL=https://arbitrum-sepolia.infura.io/v3/<YOUR_INFURA_KEY>
AVAX_FUJI_RPC_URL=https://avalanche-fuji.infura.io/v3/<YOUR_INFURA_KEY>
POLYGON_AMOY_RPC_URL=https://polygon-amoy.infura.io/v3/<YOUR_INFURA_KEY>

# ── Mainnet RPC URLs ───────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/<YOUR_INFURA_KEY>
OP_RPC_URL=https://optimism-mainnet.infura.io/v3/<YOUR_INFURA_KEY>
BASE_RPC_URL=https://base-mainnet.infura.io/v3/<YOUR_INFURA_KEY>
ARB_RPC_URL=https://arbitrum-mainnet.infura.io/v3/<YOUR_INFURA_KEY>
AVAX_RPC_URL=https://avalanche-mainnet.infura.io/v3/<YOUR_INFURA_KEY>
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/<YOUR_INFURA_KEY>

# ── Block Explorer API Keys (for --verify) ────────────────────────────────────
ETHERSCAN_API_KEY=
OP_ETHERSCAN_API_KEY=
BASE_ETHERSCAN_API_KEY=
ARB_ETHERSCAN_API_KEY=
SNOWTRACE_API_KEY=
POLYGONSCAN_API_KEY=
